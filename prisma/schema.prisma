generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  subscriptionStatus   SubscriptionStatus @default(FREE)
  subscriptionTier     SubscriptionTier   @default(FREE)
  subscriptionEndsAt   DateTime?
  isAdmin              Boolean  @default(false)
  hasAiAddon           Boolean  @default(false)
  aiAddonSubscriptionId String? @unique

  accounts      Account[]
  sessions      Session[]
  pantryItems   PantryItem[]
  ingredients   Ingredient[]
  recipes       Recipe[]
  shoppingLists ShoppingList[]
  plates        Plate[]
  sales         Sale[]
  deliveries    Delivery[]
  suppliers     Supplier[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model PantryItem {
  id         String    @id @default(cuid())
  userId     String
  name       String
  quantity   Decimal   @db.Decimal(10, 3)
  unit       String
  category   String?
  location   String?
  minStock   Decimal?  @db.Decimal(10, 3)
  cost       Decimal?  @db.Decimal(10, 2)
  expiryDate DateTime?
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Ingredient {
  id          String   @id @default(cuid())
  userId      String
  name        String
  unit        String
  costPerUnit Decimal  @db.Decimal(10, 4)
  category    String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeIngredients RecipeIngredient[]
  plateComponents   PlateComponent[]
  @@index([userId])
}

model Recipe {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?  @db.Text
  servings      Int      @default(1)
  prepTime      Int?
  cookTime      Int?
  category      String?
  notes         String?  @db.Text
  isAiGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients   RecipeIngredient[]
  plateComponents PlateComponent[]
  shoppingListItems ShoppingListItem[]
  @@index([userId])
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Decimal    @db.Decimal(10, 3)
  unit         String?
  notes        String?
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  @@unique([recipeId, ingredientId])
}

model ShoppingList {
  id          String   @id @default(cuid())
  userId      String
  name        String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ShoppingListItem[]
  @@index([userId])
}

model ShoppingListItem {
  id             String       @id @default(cuid())
  shoppingListId String
  recipeId       String?
  name           String
  quantity       Decimal      @db.Decimal(10, 3)
  unit           String
  isChecked      Boolean      @default(false)
  estimatedCost  Decimal?     @db.Decimal(10, 2)
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  recipe         Recipe?      @relation(fields: [recipeId], references: [id], onDelete: SetNull)
}

model Plate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?  @db.Text
  category    String?
  sellPrice   Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  components  PlateComponent[]
  saleItems   SaleItem[]
  @@index([userId])
}

model PlateComponent {
  id           String      @id @default(cuid())
  plateId      String
  recipeId     String?
  ingredientId String?
  quantity     Decimal     @db.Decimal(10, 3)
  unit         String?
  notes        String?
  plate        Plate       @relation(fields: [plateId], references: [id], onDelete: Cascade)
  recipe       Recipe?     @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
}

model Supplier {
  id          String     @id @default(cuid())
  userId      String
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?    @db.Text
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries  Delivery[]
  @@index([userId])
}

model Delivery {
  id         String        @id @default(cuid())
  userId     String
  supplierId String?
  date       DateTime      @default(now())
  totalCost  Decimal       @db.Decimal(10, 2)
  notes      String?       @db.Text
  invoiceNum String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplier   Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items      DeliveryItem[]
  @@index([userId])
}

model DeliveryItem {
  id         String   @id @default(cuid())
  deliveryId String
  name       String
  quantity   Decimal  @db.Decimal(10, 3)
  unit       String
  unitCost   Decimal  @db.Decimal(10, 4)
  totalCost  Decimal  @db.Decimal(10, 2)
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model Sale {
  id          String     @id @default(cuid())
  userId      String
  date        DateTime   @default(now())
  totalAmount Decimal    @db.Decimal(10, 2)
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       SaleItem[]
  @@index([userId])
}

model SaleItem {
  id       String  @id @default(cuid())
  saleId   String
  plateId  String?
  name     String
  quantity Int     @default(1)
  price    Decimal @db.Decimal(10, 2)
  sale     Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  plate    Plate?  @relation(fields: [plateId], references: [id], onDelete: SetNull)
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum SubscriptionTier {
  FREE
  PRO
}
